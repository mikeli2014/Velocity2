# Keep the build context small and avoid leaking local artifacts.
node_modules
dist
.git
.gitignore
.gitattributes

# Editor / OS noise
.vscode
.idea
.DS_Store
*.swp
*.log

# Velocity-specific local-only assets that aren't needed in the container
.claude
docs
Requirement
README.md

# Local environment files (defense in depth — don't bake secrets into images)
.env
.env.*
!.env.example
