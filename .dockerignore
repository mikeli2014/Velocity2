# Keep the build context small and avoid leaking local artifacts.
node_modules
dist
.git
.gitignore
.gitattributes

# Editor / OS noise
.vscode
.idea
.DS_Store
*.swp
*.log

# Velocity-specific local-only assets that aren't needed in the container
.claude
docs
Requirement
README.md

# Test tooling — not part of the served bundle
tests
playwright.config.js
playwright.config.ts
playwright-report
test-results
cloudbuild.yaml

# Backend dev artifacts (the runtime container creates its own .data/).
apps/api/.data
apps/api/.venv
apps/api/__pycache__
apps/api/**/__pycache__
apps/api/**/*.pyc
apps/api/tests
apps/api/DESIGN.md
apps/api/CLAUDE.md
apps/api/requirements-dev.txt

# Local environment files (defense in depth — don't bake secrets into images)
.env
.env.*
!.env.example
